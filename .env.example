# Copy this file to `.env.local` and fill in real values. Never commit .env.local.

# Required: your OpenAI API key (starts with sk-...)
OPENAI_API_KEY=

# Optional: change the model. Defaults to gpt-4o-mini (cheap & fast).
# Try gpt-4o for harder tasks.
OPENAI_MODEL=gpt-4o-mini

# ---- Optional action credentials ----
# Set these to enable the corresponding action tools.

# Email sending (get a free key at https://resend.com)
RESEND_API_KEY=
# Verified sender address. Until you verify a domain with Resend, use: onboarding@resend.dev
RESEND_FROM=onboarding@resend.dev

# Telegram defaults (only needed if you want the agent to use default creds; user can also
# pass bot_token and chat_id in each prompt).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (Postgres connection string)
# Locally: run `npx prisma dev` to spin up a local Postgres automatically
# On Render: injected automatically by render.yaml fromDatabase reference
DATABASE_URL=postgresql://user:password@localhost:5432/taskpilot

# Cron secret - any random string. Set it in Render env vars.
# Your cron service must send this as x-cron-secret header.
CRON_SECRET=replace-with-a-random-secret
