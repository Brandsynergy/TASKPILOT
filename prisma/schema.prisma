generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A saved automation: a prompt + a schedule
model Automation {
  id             String    @id @default(cuid())
  name           String
  prompt         String
  scheduleType   String    // "manual" | "hourly" | "daily" | "weekly" | "monthly"
  scheduleHour   Int       @default(8)   // 0-23
  scheduleMinute Int       @default(0)   // 0-59
  scheduleDow    Int?      // 0-6, day of week (0=Sunday). Used when scheduleType=weekly
  scheduleDom    Int?      // 1-31, day of month. Used when scheduleType=monthly
  enabled        Boolean   @default(true)
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  runs           Run[]
}

// A record of each time an automation ran
model Run {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  status       String     // "running" | "success" | "failed"
  result       String?    // final summary text from the agent
  logJson      String?    // JSON-stringified LogEntry[]
  createdAt    DateTime   @default(now())
}

// Contacts stored in named lists, used for bulk/loop automations
model Contact {
  id        String   @id @default(cuid())
  listName  String   @default("default")
  name      String
  email     String?
  phone     String?
  extraJson String?  // JSON blob for any extra fields (e.g. {"city":"London"})
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listName])
}
